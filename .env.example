# ─── Model Configuration ───────────────────────────────────────
# Leave blank to use only the default GitHub Copilot model.
# Fill in to enable the Azure OpenAI option in the model selector.

# Azure OpenAI endpoint (e.g. https://<resource>.openai.azure.com)
AZURE_OPENAI_BASE_URL=

# Azure OpenAI API key
AZURE_OPENAI_API_KEY=

# Deployed model/deployment name (e.g. gpt-4o, gpt-4o-mini)
AZURE_OPENAI_DEPLOYMENT=

# Azure OpenAI API version (default: 2024-10-21)
AZURE_OPENAI_API_VERSION=2024-10-21

# ─── Server ────────────────────────────────────────────────────
PORT=3001
