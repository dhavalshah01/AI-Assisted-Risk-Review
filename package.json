{
  "name": "ai-assisted-broker-portfolio-review",
  "version": "1.0.0",
  "description": "AI-Assisted Broker Portfolio Risk Review — GitHub Copilot SDK Demo",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:api": "tsx watch src/api/server.ts",
    "dev:web": "vite --config src/web/vite.config.ts",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "build:api": "tsc -p src/api/tsconfig.json",
    "build:web": "vite build --config src/web/vite.config.ts",
    "build": "npm run build:api && npm run build:web",
    "start": "node dist/api/server.js"
  },
  "dependencies": {
    "@github/copilot-sdk": "^0.1.30",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.21.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.1.0",
    "puppeteer": "^24.38.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
